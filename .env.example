# ── Обов'язкові змінні ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxxxxxxxx
ADMIN_TELEGRAM_ID=123456789

GEMINI_API_KEY=your_gemini_api_key_here
# Опційно: скільки спроб при 429 від Gemini (за замовчуванням 10)
# GEMINI_MAX_RETRIES=10
PEXELS_API_KEY=your_pexels_api_key_here

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Отримай на: https://console.upstash.com/redis → Create Database → REST API
UPSTASH_REDIS_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token_here

# ── Render.com ────────────────────────────────────────────────────────────────
RENDER_URL=https://your-app-name.onrender.com
PORT=8080

# ── Розклад ───────────────────────────────────────────────────────────────────
BOT_TIMEZONE=Europe/Kyiv
POST_HOUR=10
POST_MINUTE=0
